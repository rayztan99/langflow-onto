#!/bin/bash
set -euo pipefail

LANGFLOW_BASE_URL="/langflow_onto"
LANGFLOW_BIN="/home/raytan/application/langflow-onto/.venv/bin/langflow"
VENV_ACTIVATE="/home/raytan/application/langflow-onto/.venv/bin/activate"
LOG_FILE="/home/raytan/application/langflow-onto/langflow.log"
DO_NOT_TRACK=true
PORT=7860
PID_FILE="/tmp/langflow.pid"

usage() {
    echo "Usage: $0 {start|stop|restart}"
    exit 1
}

kill_langflow() {
    if [ -f "$PID_FILE" ]; then
        local pid
        pid=$(cat "$PID_FILE")
        kill -TERM "$pid" >/dev/null 2>&1 || true
        rm -f "$PID_FILE"
    fi
    pkill -f "langflow run.*--port $PORT" || true
    echo "Langflow processes stopped."
}

start_langflow() {
    kill_langflow
    sleep 1

    # Start in backend-only mode to avoid missing frontend
    nohup bash -c "
        source '$VENV_ACTIVATE' &&
        export LANGFLOW_BASE_URL='$LANGFLOW_BASE_URL' DO_NOT_TRACK='$DO_NOT_TRACK' &&
        exec '$LANGFLOW_BIN' run \
            --host 0.0.0.0 \
            --port '$PORT' \
            --backend-only
    " > "$LOG_FILE" 2>&1 &

    echo $! > "$PID_FILE"
    echo "Langflow started on port $PORT (backend-only). Logs: $LOG_FILE"
}

stop_langflow() {
    kill_langflow
}

case "${1:-}" in
    start)   start_langflow ;;
    stop)    stop_langflow ;;
    restart) stop_langflow; sleep 2; start_langflow ;;
    *)       usage ;;
esac
